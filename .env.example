# Anthropic Claude API (textinnehåll, faktagranskning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 (videosökning i video-block + undertextinfo)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Server
PORT=3000

# PostgreSQL (Neon eller annan managed Postgres) — lektionslagring
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

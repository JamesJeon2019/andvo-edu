# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 (videosökning i video-block + undertextinfo)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Unsplash (valfri) — reservbildkälla om Wikimedia Commons inte gav en bra
# bild. Utan denna visas ändå Wikimedia-bilder eller en platshållare.
# Gratis nyckel: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Server
PORT=3000

# Framtida nycklar (läggs till senare)
# OPENAI_API_KEY=your_openai_key_here   # för TTS-röst
# DATABASE_URL=your_postgres_url_here   # för PostgreSQL

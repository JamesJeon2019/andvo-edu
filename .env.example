# Anthropic Claude API (textinnehåll, faktagranskning + Claude Vision-relevanskontroll av bilder)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 (videosökning i video-block + undertextinfo).
# Samma Google-konto/projekt kan användas för GOOGLE_API_KEY nedan.
YOUTUBE_API_KEY=your_youtube_api_key_here

# Google Custom Search API (bildsökning för lektionsscener). Skapa en
# sökmotor på https://programmablesearchengine.google.com och aktivera
# bildsökning. GOOGLE_API_KEY kan återanvändas från YouTube-uppsättningen
# om den kommer från samma Google Cloud-projekt.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# OpenAI API — DALL-E 3-reserv när ingen Google-bild klarar Claude Visions
# relevanskontroll. Nyckel: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server
PORT=3000

# Framtida nycklar (läggs till senare)
# DATABASE_URL=your_postgres_url_here   # för PostgreSQL
